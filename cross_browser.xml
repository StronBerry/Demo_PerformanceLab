<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="SauceDemoCrossBrowserSuite" parallel="tests" thread-count="2">

    <test name="Chrome tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="saucedemo.tests.LoginTest"/>
            <class name="saucedemo.tests.IncorrectLoginTest"/>
            <class name="saucedemo.tests.AddProductsToCartTest"/>
            <class name="saucedemo.tests.CartTest"/>
        </classes>
    </test>

    <test name="Safari tests">
        <parameter name="browser" value="safari"/>
        <classes>
            <class name="saucedemo.tests.LoginTest"/>
            <class name="saucedemo.tests.IncorrectLoginTest"/>
            <class name="saucedemo.tests.AddProductsToCartTest"/>
            <class name="saucedemo.tests.CartTest"/>
        </classes>
    </test>

</suite>